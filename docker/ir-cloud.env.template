# Ephemeral cloud-IR container configuration — TEMPLATE.
# Copy to ir-cloud.env, fill in, then run (nothing persists on the host):
#   podman run --rm --env-file docker/ir-cloud.env --tmpfs /work ir-cloud:latest
# For GCP, also mount the key:  -v /path/sa.json:/secrets/gcp-sa.json:ro

# -- target -------------------------------------------------------------------
IR_PROVIDER=aws              # aws | azure | gcp
IR_TARGET=10.0.0.5           # instance private IP / name / id
IR_REGION=us-east-1
# IR_INCIDENT_ID=case-2026-0620

# -- threat IOCs (optional) ---------------------------------------------------
# IR_C2_IPS=45.66.77.88
# IR_C2_DOMAINS=evil.test

# -- actions ------------------------------------------------------------------
IR_CONTAIN=0                 # 1 = isolate the workload (mutates infra)
IR_SNAPSHOT_DISKS=0          # 1 = acquire disk snapshots (billable)

# -- locked-down evidence storage (terraform/<provider>/) ---------------------
IR_EVIDENCE_BUCKET=my-ir-evidence    # S3/GCS bucket name or Azure storage account
IR_PROVISION_EVIDENCE=0              # 1 = terraform-apply the WORM bucket before upload
IR_EVIDENCE_RETENTION_DAYS=365
IR_EVIDENCE_CONTAINER=ir-evidence    # Azure blob container name

# -- AI incident review (optional, advisory) ----------------------------------
# Uses the provider's NATIVE LLM: aws->Bedrock (Claude Opus), gcp->Vertex (Gemini),
# azure->Azure OpenAI. Defaults to each provider's latest; override per provider.
IR_LLM_REVIEW=0             # 1 = run an AI incident review after reporting
# IR_LLM_MODEL=             # override model (e.g. anthropic.claude-opus-4-8 / gemini-2.0-flash / <azure-deployment>)
# IR_GCP_PROJECT=           # required for gcp/Vertex
# IR_LLM_BASE_URL=          # Azure OpenAI: https://<resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=     # Azure OpenAI key

# -- ephemeral hygiene --------------------------------------------------------
IR_WIPE_WORKDIR=1            # wipe local scratch after upload (default on)
# IR_DRY_RUN=1               # print the collector command and exit (no execution)

# -- credentials — pass at run time, NEVER baked into the image ---------------
# AWS:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# Azure (service principal):
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
# GCP (mount the key file, then point to it):
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json
