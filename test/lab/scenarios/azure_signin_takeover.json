  "azure": {
    "signin_logs": {"value": [
      {"userPrincipalName": "victim@corp.test", "ipAddress": "203.0.113.9",
       "clientAppUsed": "Browser", "status": {"errorCode": 50126}},
      {"userPrincipalName": "victim@corp.test", "ipAddress": "203.0.113.9",
       "clientAppUsed": "Browser", "status": {"errorCode": 0}},
